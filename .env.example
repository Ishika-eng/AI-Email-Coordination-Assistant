# ─── Assistant Identity ───────────────────────────────────────────────
ASSISTANT_EMAIL=your-assistant@gmail.com
ASSISTANT_NAME=AI Email Assistant
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# ─── Google OAuth (for Calendar API & Gmail API thread access) ────────
# Download credentials.json from Google Cloud Console and place in project root
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# ─── LLM Configuration (both are FREE) ───────────────────────────────
# Primary: Ollama running locally (brew install ollama && ollama pull llama3)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Fallback: Groq free-tier API (sign up at console.groq.com — no credit card)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ─── Scheduling Settings ──────────────────────────────────────────────
CALENDAR_TIMEZONE=Asia/Kolkata
POLL_INTERVAL_SECONDS=60
MIN_PARTICIPANTS_TO_SCHEDULE=2

# ─── Dashboard ───────────────────────────────────────────────────────
DASHBOARD_PORT=8000
